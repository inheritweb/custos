#!/usr/bin/env bash
set -euo pipefail

CUSTOS_LIB_DIR="${CUSTOS_LIB_DIR:-$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/../lib" && pwd)}"
CUSTOS_BIN="${CUSTOS_BIN:-$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)/custos}"

# shellcheck source=../lib/logging.sh
source "$CUSTOS_LIB_DIR/logging.sh"
# shellcheck source=../lib/config.sh
source "$CUSTOS_LIB_DIR/config.sh"
# shellcheck source=../lib/restic.sh
source "$CUSTOS_LIB_DIR/restic.sh"
# shellcheck source=../lib/status.sh
source "$CUSTOS_LIB_DIR/status.sh"
# shellcheck source=../lib/restore.sh
source "$CUSTOS_LIB_DIR/restore.sh"
# shellcheck source=../lib/password.sh
source "$CUSTOS_LIB_DIR/password.sh"
# shellcheck source=../lib/tui.sh
source "$CUSTOS_LIB_DIR/tui.sh"

usage() {
  cat <<'USAGE'
Usage:
  custos [command] [args]

Running custos without a command opens the interactive TUI.

Commands:
  setup                        Configure remote storage and initialize repository
  init                         Initialize the configured restic repository
  backup [--dry-run]           Back up configured include paths
  snapshots [args...]          List repository snapshots
  ls <snapshot> [path]         List files in a snapshot
  restore <snapshot> [path]    Restore a snapshot or path
  check                        Check repository health
  doctor                       Check local dependencies and config
  forget [--dry-run]           Apply configured retention policy
  prune                        Prune repository data
  unlock                       Remove stale restic locks
  status                       Show repository and backup status
  tui                          Open the interactive terminal UI
  uninstall                    Remove the installed command and app files
  jobs list                    Show configured backup jobs
  jobs add <id> --source <path> --remote <remote:path>
  jobs remove <id>             Remove a backup job
  jobs default <id>            Set default backup job
  remote setup                 Configure the configured remote backend
  remote check                 Check the configured remote backend
  password setup               Create/check an optional stored backup password
  password status              Show how repository passwords are supplied
  paths list                   Show configured include/exclude paths
  paths include add <path>     Add a backup include path
  paths include remove <path>  Remove a backup include path
  paths exclude add <pattern>  Add a backup exclude pattern
  paths exclude remove <pattern>

Config:
  config show                  Print effective config JSON
  config validate              Validate config shape and adapter support
  config edit                  Open config in $EDITOR
  config restore               Restore config from an existing remote repository

Options accepted by restore:
  --target <path>              Restore target directory
  --original                   Restore to original locations
  --dry-run                    Preview restore where supported
  --yes                        Skip confirmation prompt

Environment:
  CUSTOS_CONFIG        Override config path
  CUSTOS_JOB           Select a configured backup job
  CUSTOS_DRY_RUN       Set to 1 to print backend commands
USAGE
}

CMD_ARGS=()

parse_job_option() {
  CMD_ARGS=()
  while (($#)); do
    case "$1" in
      --job)
        shift
        (($#)) || die "--job requires a value"
        export CUSTOS_JOB="$1"
        shift
        ;;
      --job=*)
        export CUSTOS_JOB="${1#--job=}"
        shift
        ;;
      *)
        CMD_ARGS+=("$1")
        shift
        ;;
    esac
  done
}

require_command() {
  local command_name="$1"
  if ! command -v "$command_name" >/dev/null 2>&1; then
    return 1
  fi
}

require_runtime_dependencies() {
  local -a missing=()
  local command_name

  for command_name in jq restic rclone; do
    if ! require_command "$command_name"; then
      missing+=("$command_name")
    fi
  done

  if ((${#missing[@]} > 0)); then
    log_error "Missing required dependencies: ${missing[*]}"
    log_info "Install them with:"
    log_info "  sudo pacman -S --needed ${missing[*]}"
    log_info "  sudo apt-get install ${missing[*]}"
    log_info "  sudo dnf install ${missing[*]}"
    log_info "Then rerun: custos doctor"
    exit 1
  fi

}

cmd_doctor() {
  local failed=0
  local command_name

  printf 'Checking custos environment...\n'

  for command_name in jq restic rclone; do
    if require_command "$command_name"; then
      printf 'ok: %s found at %s\n' "$command_name" "$(command -v "$command_name")"
    else
      printf 'missing: %s\n' "$command_name"
      failed=1
    fi
  done

  if command -v jq >/dev/null 2>&1; then
    if config_validate; then
      printf 'ok: config is valid\n'
    else
      failed=1
    fi

    local password_command password_executable
    password_command="$(config_password_command 2>/dev/null || true)"
    if [[ -n "$password_command" ]]; then
      password_executable="${password_command%% *}"
      if require_command "$password_executable"; then
        printf 'ok: password command found at %s\n' "$(command -v "$password_executable")"
        if bash -lc "$password_command" >/dev/null 2>&1; then
          printf 'ok: backup password is available\n'
        else
          printf 'missing: backup password is not available from configured command\n'
          failed=1
        fi
      else
        printf 'missing: backup password manager %s\n' "$password_executable"
        failed=1
      fi
    else
      printf 'ok: no stored backup password configured; commands will prompt when needed\n'
    fi
  else
    printf 'skipped: config validation requires jq\n'
  fi

  if ((failed)); then
    printf '\nInstall missing dependencies with:\n'
    printf '  sudo pacman -S --needed jq restic rclone\n'
    printf '  sudo apt-get install jq restic rclone\n'
    printf '  sudo dnf install jq restic rclone\n'
    return 1
  fi

  printf 'ok: environment is ready\n'
}

cmd_config() {
  local subcommand="${1:-}"
  shift || true

  case "$subcommand" in
    show)
      config_print
      ;;
    validate)
      config_validate
      remote_load
      log_success "Config is valid"
      ;;
    edit)
      config_ensure_exists
      "${EDITOR:-vi}" "$CUSTOS_CONFIG"
      ;;
    restore)
      config_restore_from_repository "$@"
      ;;
    ""|-h|--help|help)
      cat <<'USAGE'
Usage:
  custos config show
  custos config validate
  custos config edit
  custos config restore [--repository <url>] [--yes]
USAGE
      ;;
    *)
      die "Unknown config command: $subcommand"
      ;;
  esac
}

config_restore_from_repository() {
  require_command jq || die "Missing dependency: jq"
  require_command rclone || die "Missing dependency: rclone"

  local repository="" yes=0 remote_name="gdrive" remote_path="backups/home"
  local target_dir restored_config config_dir

  while (($#)); do
    case "$1" in
      --repository)
        shift
        (($#)) || die "--repository requires a value"
        repository="$1"
        shift
        ;;
      --remote)
        shift
        (($#)) || die "--remote requires a value"
        remote_name="${1%:}"
        shift
        ;;
      --path)
        shift
        (($#)) || die "--path requires a value"
        remote_path="$1"
        shift
        ;;
      --yes|-y)
        yes=1
        shift
        ;;
      *)
        die "Unknown config restore option: $1"
        ;;
    esac
  done

  if [[ -z "$repository" ]]; then
    repository="rclone:${remote_name}:${remote_path}"
  else
    case "$repository" in
      rclone:*:*)
        local rest="${repository#rclone:}"
        remote_name="${rest%%:*}"
        remote_path="${rest#*:}"
        ;;
      *)
        die "Only rclone repositories are supported for config restore"
        ;;
    esac
  fi

  if [[ -f "$CUSTOS_CONFIG" && "$yes" != "1" ]]; then
    die "Config already exists at $CUSTOS_CONFIG. Use --yes to overwrite."
  fi

  target_dir="$(mktemp -d)"
  restored_config="$target_dir/config.json"

  rclone copyto "${remote_name}:${remote_path}/.custos/config.json" "$restored_config" >/dev/null ||
    die "No custos config found at ${remote_name}:${remote_path}/.custos/config.json"

  jq -e . "$restored_config" >/dev/null || die "Restored config is not valid JSON"

  config_dir="$(dirname -- "$CUSTOS_CONFIG")"
  mkdir -p "$config_dir"
  cp "$restored_config" "$CUSTOS_CONFIG"
  config_migrate_if_needed
  rm -rf "$target_dir"
  log_success "Restored config to $CUSTOS_CONFIG"
}

cmd_init() {
  require_runtime_dependencies
  parse_job_option "$@"
  config_validate
  remote_load
  remote_check
  restic_init
}

cmd_setup() {
  require_runtime_dependencies
  parse_job_option "$@"
  config_validate
  remote_load
  remote_setup
  restic_init
  log_success "Setup complete"
}

cmd_uninstall() {
  local yes=0 dry_run=0 keep_local_data=0 force=0
  local install_bin install_dir wrapper config_dir state_dir

  while (($#)); do
    case "$1" in
      --yes|-y)
        yes=1
        shift
        ;;
      --dry-run)
        dry_run=1
        shift
        ;;
      --keep-local-data)
        keep_local_data=1
        shift
        ;;
      --force)
        force=1
        shift
        ;;
      -h|--help|help)
        cat <<'USAGE'
Usage:
  custos uninstall [--yes] [--dry-run] [--keep-local-data] [--force]

Removes the installed custos command wrapper, app files, local config,
and local state. Backup repositories and rclone remotes are left alone.

Options:
  --yes                 Do not ask for confirmation
  --dry-run             Print what would be removed
  --keep-local-data     Keep local config and state directories
  --force               Allow uninstall even if this looks like a source checkout
USAGE
        return 0
        ;;
      *)
        die "Unknown uninstall option: $1"
        ;;
    esac
  done

  install_bin="${CUSTOS_BIN:-$0}"
  install_dir="$(cd -- "$(dirname -- "$install_bin")/.." && pwd)"
  wrapper="$(command -v custos 2>/dev/null || true)"
  config_dir="$(dirname -- "$CUSTOS_CONFIG")"
  state_dir="$CUSTOS_STATE_DIR"

  if [[ "$force" != "1" && ( -d "$install_dir/.git" || -f "$install_dir/scripts/install.sh" ) ]]; then
    log_error "Refusing to uninstall from a source checkout: $install_dir"
    log_info "Run this from the installed wrapper, or pass --force if this is intentional."
    return 1
  fi

  printf 'This will remove:\n'
  [[ -n "$wrapper" ]] && printf '  %s\n' "$wrapper"
  printf '  %s\n' "$install_dir"
  if [[ "$keep_local_data" == "0" ]]; then
    printf '  %s\n' "$config_dir"
    printf '  %s\n' "$state_dir"
  else
    printf '\nLocal config and state will be kept:\n'
    printf '  %s\n' "$config_dir"
    printf '  %s\n' "$state_dir"
  fi

  if [[ "$yes" != "1" && "$dry_run" != "1" ]]; then
    local answer
    printf '\nContinue with uninstall? [y/N] ' >/dev/tty
    IFS= read -r answer </dev/tty || return 1
    [[ "$answer" == "y" || "$answer" == "Y" ]] || {
      log_info "Uninstall cancelled."
      return 0
    }
  fi

  if [[ "$dry_run" == "1" ]]; then
    [[ -n "$wrapper" ]] && printf 'dry-run: rm -f %q\n' "$wrapper"
    printf 'dry-run: rm -rf %q\n' "$install_dir"
    if [[ "$keep_local_data" == "0" ]]; then
      printf 'dry-run: rm -rf %q\n' "$config_dir"
      printf 'dry-run: rm -rf %q\n' "$state_dir"
    fi
    return 0
  fi

  [[ -n "$wrapper" ]] && rm -f -- "$wrapper"
  rm -rf -- "$install_dir"

  if [[ "$keep_local_data" == "0" ]]; then
    rm -rf -- "$config_dir" "$state_dir"
  fi

  log_success "Uninstalled custos."
}

cmd_backup() {
  require_runtime_dependencies
  parse_job_option "$@"
  config_validate
  remote_load
  remote_check
  restic_backup "${CMD_ARGS[@]}"
}

cmd_snapshots() {
  require_runtime_dependencies
  parse_job_option "$@"
  config_validate
  remote_load
  restic_snapshots "${CMD_ARGS[@]}"
}

cmd_ls() {
  require_runtime_dependencies
  parse_job_option "$@"
  config_validate
  remote_load
  restic_ls "${CMD_ARGS[@]}"
}

cmd_restore() {
  require_runtime_dependencies
  parse_job_option "$@"
  config_validate
  remote_load
  restore_run "${CMD_ARGS[@]}"
}

cmd_check() {
  require_runtime_dependencies
  parse_job_option "$@"
  config_validate
  remote_load
  restic_check "${CMD_ARGS[@]}"
}

cmd_forget() {
  require_runtime_dependencies
  parse_job_option "$@"
  config_validate
  remote_load
  restic_forget "${CMD_ARGS[@]}"
}

cmd_prune() {
  require_runtime_dependencies
  parse_job_option "$@"
  config_validate
  remote_load
  restic_prune "${CMD_ARGS[@]}"
}

cmd_unlock() {
  require_runtime_dependencies
  parse_job_option "$@"
  config_validate
  remote_load
  restic_unlock "${CMD_ARGS[@]}"
}

cmd_status() {
  require_runtime_dependencies
  parse_job_option "$@"
  status_show "${CMD_ARGS[@]}"
}

cmd_remote() {
  parse_job_option "$@"
  local subcommand="${CMD_ARGS[0]:-}"
  set -- "${CMD_ARGS[@]:1}"

  require_runtime_dependencies
  config_validate
  remote_load

  case "$subcommand" in
    setup)
      remote_setup "$@"
      ;;
    check)
      remote_check "$@"
      log_success "Remote is ready"
      ;;
    ""|-h|--help|help)
      cat <<'USAGE'
Usage:
  custos remote setup
  custos remote check
USAGE
      ;;
    *)
      die "Unknown remote command: $subcommand"
      ;;
  esac
}

cmd_jobs() {
  local subcommand="${1:-}"
  shift || true

  require_command jq || die "Missing dependency: jq"
  config_validate

  case "$subcommand" in
    list)
      printf 'ID\tName\tRemote\tPath\tDefault\n'
      config_jobs_list
      ;;
    add)
      local id="${1:-}" name="" source="" remote=""
      [[ -n "$id" ]] || die "Usage: custos jobs add <id> --source <path> --remote <remote:path> [--name <name>]"
      shift || true
      while (($#)); do
        case "$1" in
          --name)
            shift
            (($#)) || die "--name requires a value"
            name="$1"
            shift
            ;;
          --source)
            shift
            (($#)) || die "--source requires a value"
            source="$1"
            shift
            ;;
          --remote)
            shift
            (($#)) || die "--remote requires a value"
            remote="$1"
            shift
            ;;
          *)
            die "Unknown jobs add option: $1"
            ;;
        esac
      done
      config_job_add "$id" "$name" "$source" "$remote"
      log_success "Added job: $id"
      ;;
    remove)
      local id="${1:-}"
      [[ -n "$id" ]] || die "Usage: custos jobs remove <id>"
      config_job_remove "$id"
      log_success "Removed job: $id"
      ;;
    default|select)
      local id="${1:-}"
      [[ -n "$id" ]] || die "Usage: custos jobs default <id>"
      config_job_set_default "$id"
      log_success "Default job: $id"
      ;;
    ""|-h|--help|help)
      cat <<'USAGE'
Usage:
  custos jobs list
  custos jobs add <id> --source <path> --remote <remote:path> [--name <name>]
  custos jobs remove <id>
  custos jobs default <id>
USAGE
      ;;
    *)
      die "Unknown jobs command: $subcommand"
      ;;
  esac
}

cmd_password() {
  local subcommand="${1:-}"
  shift || true

  require_command jq || die "Missing dependency: jq"
  config_validate

  case "$subcommand" in
    setup)
      password_setup "$@"
      ;;
    status)
      password_status "$@"
      ;;
    ""|-h|--help|help)
      cat <<'USAGE'
Usage:
  custos password setup
  custos password status
USAGE
      ;;
    *)
      die "Unknown password command: $subcommand"
      ;;
  esac
}

cmd_paths() {
  parse_job_option "$@"
  local subcommand="${CMD_ARGS[0]:-}"
  set -- "${CMD_ARGS[@]:1}"

  require_command jq || die "Missing dependency: jq"
  config_validate

  case "$subcommand" in
    list)
      config_paths_list
      ;;
    include|exclude)
      local kind="$subcommand"
      local action="${1:-}"
      local value="${2:-}"

      case "$action" in
        add)
          [[ -n "$value" ]] || die "Usage: custos paths $kind add <path-or-pattern>"
          value="$(config_compact_home_path "$value")"
          config_paths_add "$kind" "$value"
          log_success "Added $kind: $value"
          ;;
        remove)
          [[ -n "$value" ]] || die "Usage: custos paths $kind remove <path-or-pattern>"
          value="$(config_compact_home_path "$value")"
          config_paths_remove "$kind" "$value"
          log_success "Removed $kind: $value"
          ;;
        *)
          die "Usage: custos paths $kind <add|remove> <path-or-pattern>"
          ;;
      esac
      ;;
    ""|-h|--help|help)
      cat <<'USAGE'
Usage:
  custos paths list
  custos paths include add <path>
  custos paths include remove <path>
  custos paths exclude add <pattern>
  custos paths exclude remove <pattern>
USAGE
      ;;
    *)
      die "Unknown paths command: $subcommand"
      ;;
  esac
}

main() {
  local command_name="${1:-}"
  shift || true

  case "$command_name" in
    setup) cmd_setup "$@" ;;
    init) cmd_init "$@" ;;
    backup) cmd_backup "$@" ;;
    snapshots) cmd_snapshots "$@" ;;
    ls) cmd_ls "$@" ;;
    restore) cmd_restore "$@" ;;
    check) cmd_check "$@" ;;
    doctor) cmd_doctor "$@" ;;
    forget) cmd_forget "$@" ;;
    prune) cmd_prune "$@" ;;
    unlock) cmd_unlock "$@" ;;
    status) cmd_status "$@" ;;
    tui) tui_main "$@" ;;
    uninstall) cmd_uninstall "$@" ;;
    jobs) cmd_jobs "$@" ;;
    remote) cmd_remote "$@" ;;
    password) cmd_password "$@" ;;
    paths) cmd_paths "$@" ;;
    config) cmd_config "$@" ;;
    "") tui_main "$@" ;;
    -h|--help|help) usage ;;
    *)
      usage >&2
      die "Unknown command: $command_name"
      ;;
  esac
}

main "$@"
